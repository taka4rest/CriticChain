# CriticChain Configuration (OSS / Lite Version)
# Copy this file to .env and fill in your values

# Required: Google AI API Key
# Get yours at: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_api_key_here

# Model Configuration
# Recommended: gemini-2.5-pro for quality, gemini-2.5-flash for cost savings

# Router (task classification)
MODEL_ROUTER=gemini-2.5-flash

# Core Analysis Pipeline
MODEL_LINT=gemini-2.5-flash
MODEL_ANALYZE=gemini-2.5-pro
MODEL_FACT_CHECK=gemini-2.5-flash
MODEL_DRAFT=gemini-2.5-flash
MODEL_CRITIQUE=gemini-2.5-pro
MODEL_REFINE=gemini-2.5-pro
MODEL_CONSISTENCY=gemini-2.5-flash
MODEL_JUDGE=gemini-2.5-pro
MODEL_RESEARCH=gemini-2.5-flash

# Fallback model (used when primary model times out)
FALLBACK_MODEL=gemini-2.5-pro

# --- Loop Control ---
# Maximum critique → refine iterations (default: 3)
# Prevents infinite loops and controls API costs
MAX_REFINE_ITERATIONS=3

# --- Input Validation ---
# Maximum input tokens allowed (default: 100000)
MAX_INPUT_TOKENS=100000

# Token estimation: chars × this value = estimated tokens
# Japanese text: 0.5-1.0, English: 0.25, Mixed: 0.4
TOKENS_PER_CHAR=0.4

# Note: Credit-based billing is an Enterprise feature.
# For Enterprise pricing, please contact us.

# --- Internationalization ---
# Prompt language (default: en)
# Simply specify the language code (ja/en).
CRITIC_LANGUAGE=en

# --- Tier Selection ---
# Options:
#   - auto: (Default) Tries Enterprise -> Fallback to Lite
#   - lite: Force Lite (OSS) version even if Enterprise files exist
CRITIC_TIER=lite
